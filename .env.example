IG_USERNAME=your_burner_account
IG_PASSWORD=your_burner_password
IG_TARGET_ACCOUNT=zero2sudo
# Optional but recommended on cloud VPS: skips the profile lookup API call entirely.
# Get it by running on a residential machine:
#   python3 -c "import instaloader; l=instaloader.Instaloader(); p=instaloader.Profile.from_username(l.context,'zero2sudo'); print(p.userid)"
IG_TARGET_USERID=
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
POLL_INTERVAL_SECONDS=120
DATA_DIR=./data
LOG_LEVEL=INFO
